{
  "name": "@charleschou/acc",
  "version": "0.1.3",
  "description": "Unified CLI to manage provider aliases and switch runtime environments for ClaudeCode, Codex, and Gemini.",
  "keywords": [
    "claude-code",
    "cli",
    "configuration",
    "settings",
    "management"
  ],
  "author": "charleschou",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "acc": "dist/cli.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.4",
    "commander": "^14.0.1",
    "execa": "^9.6.0",
    "proper-lockfile": "^4.1.2",
    "write-file-atomic": "^7.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.17.1",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamcharleschou/acc.git"
  }
}